# PostgreSQL connection used by the app at runtime.
# For a plain local/Docker Postgres, DATABASE_URL and DIRECT_URL can be identical:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/store_ratings?schema=public"

# For Supabase, use the pooled connection (port 6543, PgBouncer) here, e.g.:
# DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct (non-pooled) connection, used only by Prisma for migrations.
# For local/Docker Postgres this is the same URL as above.
# For Supabase, use the direct connection (port 5432), e.g.:
# DIRECT_URL="postgresql://postgres:<password>@db.xxxxxxxxxxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/store_ratings?schema=public"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET="replace-with-a-long-random-secret-string"
JWT_EXPIRES_IN="1d"

# CORS
CLIENT_ORIGIN="http://localhost:5173"
